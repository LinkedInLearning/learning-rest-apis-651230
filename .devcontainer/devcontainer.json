// For format details, see https://aka.ms/devcontainer.json. For config options, see:
// https://containers.dev/implementors/json_reference/
{
  "name": "learning-rest-apis",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspaces/learning-rest-apis-651230",
  "forwardPorts": [
    5432,
    8000
  ],
  "portsAttributes": {
    "5432": {
      "label": "PostgreSQL port",
      "onAutoForward": "silent"
    },
    "8000": {
      "label": "REST API",
      "onAutoForward": "notify"
    }
  },
  // Configure tool-specific properties.
  "customizations": {
    // Configure properties specific to Codespaces.
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    },
    // Configure properties specific to VS Code.
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        "linkedinlearning.linkedinlearning-vscode-theme",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.black-formatter",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "humao.rest-client"
      ],
      // Set *default* container specific settings.json values on container create.
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.useEnvFile": true,
        "python.linting.enabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestEnabled": false,
        "sqltools.connections": [
          {
            "name": "Local database",
            "driver": "PostgreSQL",
            "server": "db",
            "port": 5432,
            "database": "postgres",
            "username": "admin",
            "password": "LocalPasswordOnly"
          }
        ],
        "files.exclude": {
          ".ruff_cache": true,
          ".pytest_cache": true
        }
      }
    }
  },
  // Install Python dependencies. Runs during Codespaces prebuilds so it's cached.
  "updateContentCommand": "pip install --user --no-cache-dir -r requirements.txt",
  // Seed the local database once on create. The script is idempotent; docker-compose
  // depends_on.service_healthy guarantees the DB is ready before this runs.
  "postCreateCommand": "python init_db.py",
  // Start the REST API every time the codespace is attached. Runs in a visible
  // integrated terminal so learners can see the output, Ctrl+C to stop, and
  // restart with `uvicorn main:app --reload`.
  "postAttachCommand": "uvicorn main:app --reload --host 0.0.0.0 --port 8000",
  // Don't attach VS Code until dependencies are installed.
  "waitFor": "updateContentCommand",
  "remoteUser": "vscode"
}
